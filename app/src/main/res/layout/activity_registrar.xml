<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:text="Registrar Abogado"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- NOMBRE -->
                <EditText
                    android:id="@+id/txtNombre"
                    android:hint="Nombre del abogado"
                    android:inputType="text"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ "
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- DNI -->
                <EditText
                    android:id="@+id/txtDni"
                    android:hint="DNI"
                    android:inputType="number"
                    android:maxLength="8"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- ESPECIALIDAD -->
                <AutoCompleteTextView
                    android:id="@+id/etEspecializacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Especialización"
                    android:focusable="false"
                    android:clickable="true"
                    android:layout_marginTop="10dp"/>

                <!-- TELEFONO -->
                <EditText
                    android:id="@+id/txtTelefono"
                    android:hint="Teléfono"
                    android:layout_marginTop="10dp"
                    android:inputType="number"
                    android:maxLength="9"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- CORREO -->
                <AutoCompleteTextView
                    android:id="@+id/etCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ingresa tu correo"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <!-- BIOGRAFIA -->
                <EditText
                    android:id="@+id/txtBiografia"
                    android:hint="Biografía del abogado"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- BOTON -->
                <Button
                    android:id="@+id/btnGuardar"
                    android:text="Guardar Abogado"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>