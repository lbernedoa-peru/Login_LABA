<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fondo_suave"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="vertical">

        <!-- TITULO -->
        <TextView
            android:text="Registrar Abogado"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- TARJETA FORMULARIO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- NOMBRE -->
                <EditText
                    android:id="@+id/txtNombre"
                    android:hint="Nombre del abogado"
                    android:inputType="textPersonName"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ "
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- DNI -->
                <EditText
                    android:id="@+id/txtDni"
                    android:hint="DNI"
                    android:inputType="number"
                    android:maxLength="8"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- ESPECIALIDAD -->
                <AutoCompleteTextView
                    android:id="@+id/etEspecializacion"
                    android:hint="Especialización"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- TELEFONO -->
                <EditText
                    android:id="@+id/txtTelefono"
                    android:hint="Teléfono"
                    android:inputType="phone"
                    android:maxLength="9"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- CORREO -->
                <AutoCompleteTextView
                    android:id="@+id/etCorreo"
                    android:hint="Correo electrónico"
                    android:inputType="textEmailAddress"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- BIOGRAFIA -->
                <EditText
                    android:id="@+id/txtBiografia"
                    android:hint="Biografía del abogado"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- BOTON -->
                <Button
                    android:id="@+id/btnGuardar"
                    android:text="Guardar Abogado"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#1565C0"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>